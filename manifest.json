{
  "manifest_version": 2,
  "name": "No You Dont",
  "version": "0.1.1",
  "description": "Extensión que te impide visitar sitios web.",
  "browser_specific_settings": {
    "gecko": {
      "id": "@noyoudont",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["tabs", "storage"],
  "background": {
    "scripts": ["dist/background/background.js"]
  },
  "browser_action": {
    "default_title": "No You Dont",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
